{
  "$schema": "https://opencode.ai/config.json",
  "default_agent": "genealogist",
  "skills": {
    "paths": [".opencode/skills"]
  },
  "permission": {
    "edit": "ask",
    "external_directory": "allow",
    "skill": {
      "*": "allow"
    }
  },
  "mcp": {
    "playwright": {
      "type": "local",
      "command": [
        "npx",
        "@playwright/mcp@latest"
      ],
      "enabled": true
    }
  }
}
