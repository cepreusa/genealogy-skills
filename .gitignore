# Node / opencode plugin deps
node_modules/

# Python
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/

# GEDCOM working files & generated output (keep the demo files, ignore the rest)
*.ged
!examples/demo.ged
!examples/demo.en.ged
!tests/fixtures/*.ged
!tests/fixtures/**/*.ged
*.bak-*.ged
*.report.html
*.tree.html

# OS / editor cruft
.DS_Store
Thumbs.db
*.swp
.idea/
.vscode/

# Never commit real family data
Family-History/
private/

# Safety net: if install.sh is ever run inside this checkout by mistake, don't
# track the skills it drops into these agent dotfolders.
/.claude/
/.codex/
/.opencode/
/.agents/
